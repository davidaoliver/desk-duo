# Database (Supabase, Neon, or any PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/database"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="https://getdeskduo.com"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple OAuth (optional)
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Super Admin - first user with this email gets SUPER_ADMIN role
SUPER_ADMIN_EMAIL="david@getdeskduo.com"

# Twilio (optional - for calling)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
